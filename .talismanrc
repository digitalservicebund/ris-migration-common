fileignoreconfig:
  - filename: gradlew
    checksum: 3238afb2aed5cb16eb7d6718077e7138059108f007b54179e9cc157c5a6e0e89
  - filename: build.gradle.kts
    allowed_patterns:
      - password
      - GITHUB_TOKEN
  - filename: .github/workflows/publish-package.yml
    allowed_patterns:
      - GITHUB_TOKEN
scopeconfig:
  - scope: node
allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - "secrets: inherit"
